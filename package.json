{
  "name": "markdown",
  "version": "3.0.0",
  "description": "A small utility to parse Markdown into sanitized HTML",
  "scripts": {
    "build": "vite build",
    "build:netlify": "vite build --outDir netlify && vite build --outDir netlify/markdown",
    "dev": "vite",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "coverage": "vitest run --coverage",
    "preview": "vite preview",
    "start": "vite",
    "test": "vitest",
    "test:run": "vitest run",
    "prepare": "husky"
  },
  "keywords": [
    "markdown",
    "parse",
    "html"
  ],
  "author": "Craig McNaughton",
  "license": "ISC",
  "dependencies": {
    "sanitize-html": "^2.12.1",
    "showdown": "^2.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@types/sanitize-html": "^2.13.0",
    "@types/showdown": "^2.0.6",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/craigmcn/markdown.git"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
